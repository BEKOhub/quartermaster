{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push origin main:*)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/guard.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "echo \"$(date -u +%FT%TZ) edit applied\" >> .claude/tool-audit.log" }
        ]
      }
    ]
  }
}
