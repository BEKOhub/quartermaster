# =============================================================================
# Quartermaster — example environment file
# -----------------------------------------------------------------------------
# Copy this to `.env` and fill in real values:   cp example.env .env
# `.env` is gitignored — NEVER commit real secrets.
#
# On a real box these belong in an encrypted vault (sops/age or systemd creds),
# loaded into the Secrets Broker's memory only. See ARCHITECTURE.md and SECURITY.md.
# Only the Broker process reads these — Claude never sees a raw key.
# =============================================================================

# -----------------------------------------------------------------------------
# RUN MODE
# -----------------------------------------------------------------------------
# MOCK_MODE=true  -> no external accounts needed. Jira/GitHub/Claude are faked
#                    so you can run the WHOLE loop locally with `docker compose up`.
# MOCK_MODE=false -> the broker talks to real Jira/GitHub and runs the real
#                    `claude -p` CLI. Requires all the keys below.
MOCK_MODE=true

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Demo only: in MOCK_MODE, pause this many seconds between pipeline stages so you
# can watch tickets move across the dashboard columns. Set 0 for instant.
MOCK_STEP_DELAY_SECONDS=3

# =============================================================================
# 1. ANTHROPIC / CLAUDE  (the worker's brain)
# =============================================================================
# Headless auth against your Max plan (preferred — uses the agent credit pool).
# Generate on your laptop with:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: pay-as-you-go API key from console.anthropic.com.
# Only ONE of OAUTH_TOKEN / API_KEY is needed. Leave the other blank.
ANTHROPIC_API_KEY=

# Path to the `claude` CLI binary (usually just "claude" on PATH).
CLAUDE_BIN=claude

# Model routing (CLI --model values). Tier per pipeline stage.
CLAUDE_MODEL_PLAN=haiku
CLAUDE_MODEL_IMPLEMENT=sonnet
CLAUDE_MODEL_REVIEW=sonnet
# Used when a ticket carries the `hard`/`arch` label.
CLAUDE_MODEL_HARD=opus

# =============================================================================
# 2. JIRA CLOUD  (the cockpit)
# =============================================================================
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_AGENT_EMAIL=agent@yourdomain.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=DEMO
# The Jira accountId (or email) of YOU, the boss — tickets get assigned here
# when the agent needs a decision / approval / review.
JIRA_BOSS_ACCOUNT_ID=

# Status names exactly as configured in your Jira workflow.
JIRA_STATUS_TODO=To Do
JIRA_STATUS_QUEUED=Queued
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_NEEDS_DECISION=Needs Decision
JIRA_STATUS_BLOCKED=Blocked
JIRA_STATUS_IN_REVIEW=In Review
JIRA_STATUS_DONE=Done

# =============================================================================
# 3. GITHUB  (where the work lands)
# =============================================================================
# Fine-grained PAT scoped to your target repository: contents R/W, pull-requests W.
# The broker policy forbids merging to main / force-push / settings changes.
GH_TOKEN=
GITHUB_REPO=your-org/your-repo
GITHUB_BASE_BRANCH=main
# Branch naming for agent work; {key} and {slug} are substituted.
GITHUB_BRANCH_PREFIX=agent/

# Optional: enable the "Connect via GitHub" OAuth button in /setup.
# Register a GitHub OAuth App at github.com/settings/developers, then paste the
# public Client ID here. No client secret needed — uses Device Authorization Flow.
# Callback URL: http://localhost  (device flow; no real callback required)
GITHUB_OAUTH_CLIENT_ID=

# Local checkout the worker operates in (one worktree per ticket lives under it).
REPO_PATH=/workspace/repo
WORKTREES_PATH=/workspace/worktrees

# =============================================================================
# 4. CLOUDFLARE  (read / propose only — broker forbids autonomous DNS/WAF edits)
# =============================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# =============================================================================
# 5. STRIPE  (read-only / TEST mode only — broker forbids any live write)
# =============================================================================
# Use a TEST-mode restricted key. Never put a live secret key on this box.
STRIPE_API_KEY=
STRIPE_MODE=test

# =============================================================================
# 6. AZURE  (read status / propose deploys — human runs prod deploys)
# =============================================================================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# =============================================================================
# 7. QUEUE  (Redis — ordering + backpressure)
# =============================================================================
REDIS_URL=redis://redis:6379/0
QUEUE_NAMESPACE=quartermaster
# Max tickets a worker may process at once (the throttle — keep low on a mini PC).
WORKER_CONCURRENCY=1
# Re-deliver a job stuck "in flight" longer than this (seconds).
JOB_VISIBILITY_TIMEOUT=1800
# Tries before a job is dead-lettered and the ticket is marked Blocked.
JOB_MAX_ATTEMPTS=3

# =============================================================================
# 8. POLLER  (intake)
# =============================================================================
# How often the intake poller queries Jira for new To-Do tickets (seconds).
POLL_INTERVAL_SECONDS=120

# -----------------------------------------------------------------------------
# DASHBOARD  (web UI — Jira-style board + live indicators)
# -----------------------------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8000

# -----------------------------------------------------------------------------
# ROLE  (process split for horizontal scale): all | poller | worker | dashboard
# Single box: leave "all". Distributed: run one poller, N workers, one dashboard.
# -----------------------------------------------------------------------------
ROLE=all

# -----------------------------------------------------------------------------
# OBSERVABILITY  (run history + optional OpenTelemetry tracing)
# -----------------------------------------------------------------------------
RUNS_DB_PATH=/workspace/data/runs.db
# Export GenAI spans to an OTLP/HTTP collector (Phoenix/Tempo/Jaeger). Needs the
# opentelemetry-* packages installed; off by default. Set the standard
# OTEL_EXPORTER_OTLP_ENDPOINT too when enabling.
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# -----------------------------------------------------------------------------
# RELIABILITY  (Tier 1: adversarial review + repair loop + acceptance + routing)
# -----------------------------------------------------------------------------
REVIEW_VOTES=3                 # adversarial reviewer panel size (majority decides)
REVIEW_MAX_REPAIRS=2           # review->implement repair rounds before Blocked
ESCALATE_MODEL_ON_RETRY=true   # bump Sonnet->Opus after a failed round
ACCEPTANCE_GATE=true           # require reviewers to confirm acceptance criteria

# -----------------------------------------------------------------------------
# SECURITY  (Tier 3: scan the diff before any PR)
# -----------------------------------------------------------------------------
SCAN_DIFFS=true
CANARY_TOKEN=QM-CANARY-do-not-exfil

# -----------------------------------------------------------------------------
# CONTEXT/COST  (Tier 4: cached repo map injected as a stable prompt prefix)
# -----------------------------------------------------------------------------
REPO_MAP_ENABLED=true
REPO_MAP_MAX_FILES=400

# -----------------------------------------------------------------------------
# NOTIFICATIONS  (ping you when a ticket needs the boss; Slack/Telegram webhook)
# -----------------------------------------------------------------------------
NOTIFY_WEBHOOK_URL=

# =============================================================================
# 9. BUDGET GUARD  (SQLite ledger + caps, USD)
# =============================================================================
BUDGET_DB_PATH=/workspace/data/ledger.db
# Per-ticket cap; a ticket exceeding it is parked in Blocked. Override per ticket
# with a `budget: N` label in Jira.
BUDGET_PER_TICKET_USD=3
# Monthly cap; near it the poller stops picking up new work.
BUDGET_MONTHLY_USD=90
# Bounded retries when build/tests fail inside the implement stage.
IMPLEMENT_MAX_RETRIES=2

# =============================================================================
# 10. AUDIT
# =============================================================================
# Append-only log of every brokered external call.
AUDIT_LOG_PATH=/workspace/data/audit.log

# =============================================================================
# 11. BUILD / TEST  (deterministic — run by the controller, zero tokens)
# =============================================================================
# Command the controller runs after the implement stage. Non-zero exit = fail,
# which feeds the failure back to the implementer (bounded by IMPLEMENT_MAX_RETRIES).
# In MOCK_MODE this is ignored.
BUILD_TEST_COMMAND=echo "no tests configured"
